    "Compatibility Mode uses a simpler brightness method and may work better on this Mac. It can be less color-accurate." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Kompatibilitätsmodus verwendet eine einfachere Helligkeitsmethode und funktioniert auf diesem Mac möglicherweise besser. Die Farbdarstellung kann weniger genau sein."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Compatibility Mode uses a simpler brightness method and may work better on this Mac. It can be less color-accurate."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El Modo de compatibilidad usa un método de brillo más sencillo y puede funcionar mejor en este Mac. Puede ser menos preciso con los colores."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le mode Compatibilité utilise une méthode de luminosité plus simple et peut mieux fonctionner sur ce Mac. Il peut être moins fidèle au niveau des couleurs."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La Modalità compatibilità usa un metodo di luminosità più semplice e potrebbe funzionare meglio su questo Mac. Può essere meno accurata nei colori."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "互換モードはよりシンプルな明るさ調整方式を使い、この Mac でうまく動作する可能性があります。色の正確さは低くなる場合があります。"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O Modo de Compatibilidade usa um método de brilho mais simples e pode funcionar melhor neste Mac. Pode ser menos preciso nas cores."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "兼容模式使用更简单的亮度方式，可能在这台 Mac 上效果更好。颜色准确性可能会降低。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "相容模式使用較簡單的亮度方法，可能在這台 Mac 上運作得更好。色彩準確度可能較低。"
          }
        }
      }
    },
