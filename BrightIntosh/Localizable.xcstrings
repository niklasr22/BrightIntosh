    "You can also use the %@ Spotlight Search to open the settings window by searching \"BrightIntosh Settings\"" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie können auch die %@ Spotlight-Suche verwenden, um das Einstellungsfenster zu öffnen, indem Sie \"BrightIntosh Einstellungen\" suchen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can also use the %@ Spotlight Search to open the settings window by searching \"BrightIntosh Settings\""
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "También puedes usar el %@ Spotlight Search para abrir la ventana de configuración buscando \"Configuración de BrightIntosh\""
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous pouvez également utiliser la recherche %@ Spotlight  pour ouvrir la fenêtre des paramètres en recherchant \"Paramètres BrightIntosh\""
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Puoi anche usare %@ nella ricerca dello Spotlight e aprire le impostazioni cercando \"Impostazioni di BrightIntosh\""
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "また、 %@ Spotlight検索から”BrightIntoshの設定”を検索して設定画面を開くこともできます。"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Pode também usar a pesquisa %@ Spotlight para abrir a janela de definições, pesquisando \"Configurações do BrightIntosh\""
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您还可以使用 %@ 聚焦搜索通过搜索“BrightIntosh 设置”来打开设置窗口"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您也可以使用 %@ Spotlight 搜索，透過搜尋「BrightIntosh 設定」來開啟設定視窗。"
          }
        }
      }
    },
    "You can still use your brightness keys to control the brightness. This slider controls how much the brightness range is shifted up." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie können weiterhin Ihre Helligkeitstasten verwenden, um die Helligkeit anzupassen. Der Schieberegler steuert, wie stark der Helligkeitsbereich nach oben verschoben wird."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can still use your brightness keys to adjust the brightness. The slider controls how much the brightness range is shifted upward."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aún puedes usar tus teclas de brillo para ajustar el brillo. El control deslizante determina cuánto se desplaza hacia arriba el rango de brillo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous pouvez toujours utiliser vos touches de luminosité pour ajuster la luminosité. Le curseur contrôle combien de la plage de luminosité est déplacée vers le haut."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Puoi utilizzare comunque i tasti della luminosità per regolarla. Lo slider controlla quanto la luminosità deve essere incrementata."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "キーボードでも明るさを調整できます。このスライダーでは明るさの範囲をずらせます。"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ainda pode usar as suas teclas de brilho para ajustar o brilho. O deslizante controla quão para cima é deslocado o intervalo de brilho."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您仍然可以使用亮度键来调节亮度。滑块控制亮度范围向上移动的幅度。"
          }
        },
        "zh-Hant" : {
