    "Your device doesn't have a built-in XDR display. Increased brightness can only be enabled for external XDR displays." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihr Gerät verfügt nicht über ein eingebautes XDR-Display. Erhöhte Helligkeit kann nur für externe XDR-Displays aktiviert werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Your device doesn't have a built-in XDR display. Increased brightness can only be enabled for external XDR displays."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tu dispositivo no tiene una pantalla XDR integrada. El aumento del brillo solo se puede activar para pantallas XDR externas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre appareil ne dispose pas d'un écran XDR intégré. L'augmentation de la luminosité ne peut être activée que pour les écrans XDR externes."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il tuo dispositivo non ha un display XDR. L’incremento della luminosità può essere abilitato per gli schermi XDR esterni."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "お使いのデバイスには内蔵XDRディスプレイが無いようです。明るさを上げられるのは外部XDRディスプレイのみになります。"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O seu dispositivo não tem um ecrã XDR incorporado. O aumento de brilho só pode ser ativado para ecrãs XDR externos."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您的设备没有内置 XDR 显示屏。只有外接 XDR 显示屏才能启用更高的亮度。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您的設備沒有內建 XDR 顯示器。只有外接 XDR 顯示器才能啟用更高的亮度。"
          }
        }
      }
    },
