    "%@ may also control display brightness or color and interfere with BrightIntosh." : {
      "comment" : "A tooltip for the menu item that warns of a potential conflict with an incompatible app. The argument is a list of the names of the conflicting apps.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ kann auch die Displayhelligkeit oder -farbe steuern und BrightIntosh beeinträchtigen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ may also control display brightness or color and interfere with BrightIntosh."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ también puede controlar el brillo o el color de la pantalla e interferir con BrightIntosh."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ peut également contrôler la luminosité ou la couleur de l'écran et interférer avec BrightIntosh."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ potrebbe anche controllare la luminosità del display o il colore e interferire con BrightIntosh."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ は表示の明るさや色の制御も行う可能性があり、BrightIntosh と干渉することがあります。"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ pode também controlar o brilho ou a cor do ecrã e interferir com o BrightIntosh."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 可能也会控制显示器的亮度或颜色，可能会干扰 BrightIntosh 的正常工作。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 也可能控制顯示器亮度或顏色並干擾 BrightIntosh。"
          }
        }
      }
    },
    "%@ may interfere with BrightIntosh because it can also adjust display brightness or color." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ kann BrightIntosh stören, da es ebenfalls die Helligkeit oder Farbe des Displays einstellen kann."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ may interfere with BrightIntosh because it can also adjust display brightness or color."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ puede interferir con BrightIntosh porque también puede ajustar el brillo o el color de la pantalla."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ peut interférer avec BrightIntosh car il peut également ajuster la luminosité ou la couleur de l'écran."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ potrebbe interferire con BrightIntosh perché può anche regolare la luminosità o il colore del display."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ は、ディスプレイの明るさや色を調整できるため、BrightIntosh と干渉する可能性があります。"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ pode interferir com o BrightIntosh porque também pode ajustar o brilho ou a cor do ecrã."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 可能会干扰 BrightIntosh，因为它也可以调整显示器的亮度或颜色。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 可能會干擾 BrightIntosh，因為它也可以調整顯示器的亮度或顏色。"
          }
        }
      }
    },
