          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Haz clic para descartar. Opción+clic para descartar y dejar de mostrar estos avisos. Control+clic para un menú."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cliquez pour fermer. Option-clic pour fermer et arrêter d'afficher ces notifications. Ctrl-clic pour un menu."
